# =====================================================================
# LibraryConnekto Frontend - Production .env for Vercel
# Copy values into Vercel Project Settings -> Environment Variables
# =====================================================================

# Backend API URL (backend may be hosted on AWS)
VITE_API_BASE_URL=https://api.libraryconnekto.me/api/v1

# Razorpay public key (frontend-safe key id)
VITE_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXX

# Retell AI — Priya voice widget (REQUIRED for production — Vite bakes these at build time)
# 1. Retell dashboard → Keys → Public Key → allow: libraryconnekto.me, www.libraryconnekto.me
# 2. Retell dashboard → Agents → Priya → Publish agent → copy Agent ID + version
# 3. Add ALL vars below in Vercel → Settings → Environment Variables → Production → Redeploy
# 4. After deploy, verify: https://libraryconnekto.me/api/retell-config (must show your keys)
#    Runtime API reads Vercel env; public/retell-config.json is a static fallback at build time
VITE_RETELL_PUBLIC_KEY=public_key_xxxxxxxxxxxxxxxxxxxxx
VITE_RETELL_VOICE_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxx
VITE_RETELL_AGENT_VERSION=2
VITE_RETELL_WIDGET_TITLE=Priya
# Optional — must match PriyaVoiceWidget.jsx (either name works)
# VITE_RETELL_WHITE_LABEL=white_label_token_xxxxxxxx
# VITE_RETELL_WHITE_LABEL_TOKEN=white_label_token_xxxxxxxx

# Android APK download (optional — defaults to GitHub Releases /latest/ URL baked into the app)
# VITE_APK_DOWNLOAD_URL=https://github.com/PrepZone-ai/LibraryConnekto_Frontend/releases/latest/download/LibraryConnekto.apk
